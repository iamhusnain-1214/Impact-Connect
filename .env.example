# Copy this file to .env for local development. On Vercel, set these as
# real Environment Variables in Project Settings instead - Vercel does not
# read .env files from the repo.

FLASK_ENV=development
FLASK_SECRET_KEY=change_this_to_a_long_random_string

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=impactconnect
# Set to false only for a local MySQL install with no SSL configured.
DB_USE_SSL=true

GEMINI_API_KEY=your_key_from_aistudio.google.com
